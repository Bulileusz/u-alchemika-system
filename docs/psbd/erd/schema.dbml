// =============================================
// U Alchemika — ERD (schemat DBML)
// Wklej do https://dbdiagram.io/d
// =============================================

// ----- Django built-in -----

Table auth_user {
  id bigint [pk, increment]
  username varchar(150) [unique, not null]
  email varchar(254)
  first_name varchar(150)
  last_name varchar(150)
  is_active boolean [default: true]
  date_joined timestamp

  Note: 'Wbudowany model użytkownika Django (django.contrib.auth)'
}

// ----- App: core -----

Table core_room {
  id bigint [pk, increment]
  name varchar(150) [not null]
  slug varchar(150) [unique, not null, note: 'URL-friendly identyfikator']
  description text
  capacity integer [not null, note: '> 0']
  base_price decimal(10,2) [not null, note: '>= 0']
  is_active boolean [default: true]
  created_at timestamp [default: `now()`]
  updated_at timestamp [note: 'auto aktualizacja']

  indexes {
    slug [name: 'room_slug_idx']
  }

  Note: 'Pokoje obiektu noclegowego'
}

Table core_roomimage {
  id bigint [pk, increment]
  room_id bigint [not null]
  image_url text [not null]
  alt_text varchar(255)
  display_order integer [default: 0]

  Note: 'Zdjęcia pokoi — kasowane kaskadowo z pokojem'
}

Table core_amenity {
  id bigint [pk, increment]
  name varchar(100) [unique, not null]
  icon varchar(100)

  Note: 'Udogodnienia (WiFi, Parking, itp.)'
}

Table core_roomamenity {
  id bigint [pk, increment]
  room_id bigint [not null]
  amenity_id bigint [not null]

  indexes {
    (room_id, amenity_id) [unique, name: 'room_amenity_unique']
  }

  Note: 'Tabela łącząca M:N — pokoje ↔ udogodnienia'
}

Table core_inquiry {
  id bigint [pk, increment]
  room_id bigint
  full_name varchar(150) [not null]
  email varchar(254) [not null]
  phone varchar(50)
  date_from date
  date_to date [note: 'CHECK: date_to >= date_from']
  guests integer [note: '> 0']
  message text [not null]
  status varchar(30) [not null, default: 'new', note: 'new / replied / closed']
  created_at timestamp [default: `now()`]

  indexes {
    status [name: 'inquiry_status_idx']
    email [name: 'inquiry_email_idx']
    created_at [name: 'inquiry_created_at_idx']
  }

  Note: 'Zapytania klientów o nocleg / formularz kontaktowy'
}

Table core_auditlog {
  id bigint [pk, increment]
  user_id bigint
  action varchar(100) [not null]
  entity_name varchar(100) [not null]
  entity_id bigint
  details text
  created_at timestamp [default: `now()`]

  Note: 'Log akcji administracyjnych'
}

Table core_propertyinfo {
  id bigint [pk, increment]
  name varchar(200) [not null]
  address varchar(255) [not null]
  phone varchar(50) [not null]
  email varchar(254) [not null]
  booking_url varchar(200)
  facebook_url varchar(200)
  description text
  check_in varchar(100)
  check_out varchar(100)
  pets_policy text
  parking_info text
  payment_info text
  breakfast_info text
  cancellation_policy text

  Note: 'Dane kontaktowe i informacje praktyczne obiektu noclegowego'
}

// ----- App: content -----

Table content_post {
  id bigint [pk, increment]
  title varchar(200) [not null]
  slug varchar(200) [unique, not null]
  content text [not null]
  is_published boolean [default: false]
  published_at timestamp
  created_at timestamp [default: `now()`]

  Note: 'Posty / aktualności'
}

Table content_attraction {
  id bigint [pk, increment]
  name varchar(150) [not null]
  description text
  location_name varchar(255)
  created_at timestamp [default: `now()`]

  Note: 'Atrakcje w okolicy obiektu'
}

// ----- Relacje -----

// 1:N — Pokój → Zdjęcia (CASCADE DELETE)
Ref: core_roomimage.room_id > core_room.id [delete: cascade]

// M:N — Pokój ↔ Udogodnienie (CASCADE obie strony)
Ref: core_roomamenity.room_id > core_room.id [delete: cascade]
Ref: core_roomamenity.amenity_id > core_amenity.id [delete: cascade]

// N:1 — Zapytanie → Pokój (SET NULL)
Ref: core_inquiry.room_id > core_room.id [delete: set null]

// N:1 — Log audytu → Użytkownik (SET NULL)
Ref: core_auditlog.user_id > auth_user.id [delete: set null]
